__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
.streamlit/secrets.toml

# Staged facts used between the mechanical pipeline step and the
# generation step. Never committed: it's the one place raw scraped
# article text can transiently live, and this repo is public.
data/pending_generation/

# analytics/ (self-service NL analytics side project)
analytics/.env
analytics/dbt/dbt_packages/
analytics/dbt/logs/
analytics/dbt/.user.yml

# analytics.duckdb and the two manifests below are build artifacts, but
# Streamlit Cloud builds from the repo alone and has no way to regenerate
# them, so the deployed analytics page needs them committed. Rebuild with
# `python -m analytics.data.generate_data && dbt parse` and commit the diff.
# The rest of target/ is local-only: docs, parse caches, per-run results.
analytics/dbt/target/*
!analytics/dbt/target/manifest.json
!analytics/dbt/target/semantic_manifest.json
